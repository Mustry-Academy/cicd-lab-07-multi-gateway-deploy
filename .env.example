# Copy this file to .env (which is gitignored) before running `docker compose up`.
# Override the defaults for local development.
#
# This lab runs THREE Ignition gateways:
#   local  — your authoring gateway (bind-mounted; you develop here, file-based)
#   dev    — runs the IMAGE built by deploy.yml (push to main)
#   prod   — runs the IMAGE promoted by release.yml (tag push v*)
#
# Unlike Lab 04, dev/prod are NOT scanned over the API — they're redeployed by
# pulling a new image and recreating the container. So day-to-day you only use
# the API key against the LOCAL gateway (file-based inner loop / trigger-scan.sh).

# ---- Ignition API key (all gateways) -------------------------------------
# The lab ships a pre-provisioned API token named `cicd` in
# services/config/resources/core/ignition/api-token/. The gateway stores only
# the SHA-256 hash of the secret; the full key (name:secret) is the value
# below. Every gateway boots from the same services/config (local via bind
# mount, dev/prod via the baked image), so this ONE key works on all three.
# Its security levels (APIToken Access/Read/Write) grant the scan endpoints.
#
# Gotcha: on the FIRST boot of a fresh container (i.e. every image deploy of
# dev/prod), Ignition's auto-commissioning resets the read/write permissions
# in security-properties, which 403s the key. Local only hits this once (its
# volume persists). Repair with:  scripts/fix-gateway-api-perms.sh dev prod
IGNITION_API_KEY=cicd:i5elT52UZSKUWYp6nEiek3XJmECOZeH-b2cM2hPa2ts

# ---- Local gateway (http://localhost:8088) ------------------------------
GATEWAY_ADMIN_USERNAME_LOCAL=admin
GATEWAY_ADMIN_PASSWORD_LOCAL=password
# Per-gateway key override; falls back to IGNITION_API_KEY above when unset.
# IGNITION_API_KEY_LOCAL=

# ---- Dev gateway (http://localhost:8089) — deploy.yml target ------------
# No API key needed: deploy is an image pull + container recreate, not a scan.
GATEWAY_ADMIN_USERNAME_DEV=admin
GATEWAY_ADMIN_PASSWORD_DEV=password

# ---- Prod gateway (http://localhost:8090) — release.yml target ----------
GATEWAY_ADMIN_USERNAME_PROD=admin
GATEWAY_ADMIN_PASSWORD_PROD=password

# ---- Image registry (OPTIONAL) ------------------------------------------
# You usually do NOT need to set this. The local scripts (build-image.sh,
# deploy-image.sh) build and run images entirely on your machine with a plain
# local name (cicd-lab-05-ignition) — no registry, no login. And the CI path
# (deploy.yml / release.yml) pushes to YOUR OWN fork's GHCR namespace
# (ghcr.io/<your-fork-owner>/cicd-lab-05-ignition), which it derives from the
# fork automatically — it never reads this value.
#
# Only set this if you want the LOCAL scripts to tag/push to your own registry,
# e.g. to manually push to your fork's GHCR. Use your own lowercase namespace:
#   IGNITION_IMAGE_REPO=ghcr.io/your-github-user/cicd-lab-05-ignition
# (Leave it commented out for the normal, registry-free local workflow.)
# IGNITION_IMAGE_REPO=

# ---- Image overrides consumed by docker-compose.yaml --------------------
# Which image the dev/prod gateways run. Leave UNSET and they fall back to the
# base Ignition image (an empty gateway) until the first deploy. The deploy
# scripts/workflows set these to a concrete tag and recreate the container.
# IGNITION_DEV_IMAGE=cicd-lab-05-ignition:local
# IGNITION_PROD_IMAGE=cicd-lab-05-ignition:local

# ---- Shared TimescaleDB sidecar ------------------------------------------
# One Postgres instance, three databases (ignition_loc, ignition_dev,
# ignition_prd). These creds are the superuser; create per-env users via
# the gateway DB connection UI if you want isolation.
POSTGRES_USER=ignition
POSTGRES_PASSWORD=ignition

# ---- GitHub Actions self-hosted runner ----------------------------------
# Auto-starts as part of `docker compose up -d`. The runner uses RUNNER_GITHUB_PAT
# (a PAT with `repo` scope) to fetch its own registration token, so you don't
# have to generate a registration token manually. Both vars MUST be set for
# the runner container to register; otherwise it'll restart-loop with an
# auth error in its logs.
#
# Reuse the same `repo`-scope PAT you created in Lab 04 — just paste it into
# RUNNER_GITHUB_PAT below. (New here? github.com/settings/tokens → Generate new
# token (classic) → tick `repo` → copy the ghp_... value.)
#
# REPO_URL is your fork (not the upstream mustry-academy repo).
# RUNNER_GITHUB_PAT lives only in .env — never commit it.
RUNNER_REPO_URL=https://github.com/<your-github-user>/cicd-lab-05-ignition-image-based-deploy
RUNNER_GITHUB_PAT=ghp_replace-me-with-a-pat-that-has-repo-scope
RUNNER_NAME=lab05-runner
