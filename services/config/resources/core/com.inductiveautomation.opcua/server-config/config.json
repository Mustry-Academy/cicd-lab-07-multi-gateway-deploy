{
  "advanced": {
    "exposedTagsEnabled": false,
    "gdsPushEnabled": false,
    "maxSessionCount": 100
  },
  "authentication": {
    "anonymousAccessAllowed": true,
    "authenticationProfile": "opcua-module"
  },
  "endpoint": {
    "bindAddresses": [
      "localhost"
    ],
    "bindPort": 62541,
    "endpointAddresses": [
      "<hostname>",
      "<localhost>"
    ],
    "messageSecurityModes": [
      "SignAndEncrypt"
    ],
    "securityPolicies": [
      "Basic256Sha256"
    ]
  },
  "redundancy": {
    "readOnlyWhenInactive": false
  }
}