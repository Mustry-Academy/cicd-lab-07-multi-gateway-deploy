# cicd-capstone — server-side environment
#
# Copy to .env ON THE SERVER (/opt/cicd-lab-07/capstone/.env). Never committed: .env
# is gitignored, and the deploy workflow never touches it. Everything that is
# NOT secret and NOT server-specific belongs in docker-compose.yaml instead,
# so it ships through git.

# ---- Gateway admin (first-boot commissioning only) ------------------------
# The username is not a secret; the password is, and therefore is NOT here —
# it lives in ./secrets/gateway_admin_password.txt (see secrets/README).
GATEWAY_ADMIN_USERNAME=admin

# ---- GitHub Actions self-hosted runner ------------------------------------
# Preferred, unattended: a FINE-GRAINED PAT scoped to only the
# Mustry-Academy/cicd-lab-07-multi-gateway-deploy repository, permissions:
# "Administration: read & write" (that is the one runner registration needs).
# The runner uses it to mint its own registration token on every start, so
# container recreation never needs a human.
RUNNER_GITHUB_PAT=

# Bootstrap fallback if the PAT does not exist yet: a registration token,
# valid 1 hour, minted from a laptop with:
#   gh api -X POST repos/Mustry-Academy/cicd-lab-07-multi-gateway-deploy/actions/runners/registration-token --jq .token
# Leave empty once RUNNER_GITHUB_PAT is set.
RUNNER_TOKEN=

RUNNER_NAME=cicd-capstone-runner
